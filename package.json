{
  "name": "viber-connect",
  "version": "0.0.0",
  "private": true,
  "description": "Viber Click-to-Chat button toolkit — link builder, UI components, and a web-based generator.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "lint": "oxlint .",
    "dev:site": "pnpm --filter site dev",
    "build:site": "pnpm --filter site build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "oxlint": "^0.18.1",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=18"
  }
}
