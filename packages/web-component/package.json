{
  "name": "@viberbutton/web-component",
  "version": "0.1.0",
  "description": "<viber-button> custom element for Viber Click-to-Chat. Drop into any HTML page.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/viber-button.global.js",
  "jsdelivr": "./dist/viber-button.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": [
    "viber",
    "click-to-chat",
    "web-component",
    "custom-element",
    "button"
  ],
  "license": "MIT",
  "dependencies": {
    "@viberbutton/core": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magnifito/viber-button.git",
    "directory": "packages/web-component"
  },
  "homepage": "https://github.com/magnifito/viber-button/tree/main/packages/web-component#readme",
  "bugs": {
    "url": "https://github.com/magnifito/viber-button/issues"
  },
  "author": "Magnifito"
}
