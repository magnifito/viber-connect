{
  "name": "@puralex/viber-connect-server",
  "version": "0.2.1",
  "description": "Framework-agnostic backend handler to validate Viber Business accounts, so partners never render a dead button.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "viber",
    "validation",
    "business-account",
    "click-to-chat"
  ],
  "license": "MIT",
  "dependencies": {
    "@puralex/viber-connect": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magnifito/viber-connect.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/magnifito/viber-connect/tree/main/packages/server#readme",
  "bugs": {
    "url": "https://github.com/magnifito/viber-connect/issues"
  },
  "author": "Magnifito"
}
