{
  "name": "@puralex/viber-connect",
  "version": "0.2.0",
  "description": "Framework-agnostic Viber Click-to-Chat deep-link builder. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "viber",
    "click-to-chat",
    "deep-link",
    "chat",
    "viber.me",
    "button"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magnifito/viber-connect.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/magnifito/viber-connect/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/magnifito/viber-connect/issues"
  },
  "author": "Magnifito"
}
